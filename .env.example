# Copy this file to .env and fill in values for local development.
# On Vercel, set these under Project Settings → Environment Variables.

# Required for the /api/analyze serverless function.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: restrict the endpoint to your deployed origin so the API key
# can't be used from anywhere else. Leave blank in development.
ALLOWED_ORIGIN=
